# Supabase (обязательно для рецептов, auth и счётчиков)
# Скопируйте этот файл в .env и подставьте свои значения.
# URL и anon key — в Supabase Dashboard → Project Settings → API (anon public).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...ваш_anon_ключ

# Stripe (обязательно для подписок)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_STRIPE_PRICE_ID=price_...          # monthly
VITE_STRIPE_PRICE_ID_YEARLY=price_...   # yearly (опционально)

# OpenAI — ТОЛЬКО как фолбэк без Supabase (не рекомендуется в продакшне)
# VITE_OPENAI_API_KEY=sk-...
