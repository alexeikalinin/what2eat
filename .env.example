# Supabase (обязательно для auth, счётчиков и прокси)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (обязательно для подписок)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_STRIPE_PRICE_ID=price_...          # monthly
VITE_STRIPE_PRICE_ID_YEARLY=price_...   # yearly (опционально)

# OpenAI — ТОЛЬКО как фолбэк без Supabase (не рекомендуется в продакшне)
# VITE_OPENAI_API_KEY=sk-...
